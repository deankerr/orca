{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Next.js Dev",
      "type": "shell",
      "command": "bun",
      "args": ["next", "dev", "--turbopack", "--port", "3020"],
      "isBackground": true,
      "problemMatcher": {
        "owner": "nextjs",
        "pattern": {
          "regexp": "^(.*)$"
        },
        "background": {
          "activeOnStart": true,
          "beginsPattern": ".",
          "endsPattern": "Ready in"
        }
      },
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "group": "dev"
      },
      "runOptions": {
        "runOn": "folderOpen"
      }
    },
    {
      "label": "Convex Dev",
      "type": "shell",
      "command": "bun",
      "args": ["convex", "dev"],
      "isBackground": true,
      "problemMatcher": {
        "base": "$tsc-watch",
        "background": {
          "activeOnStart": true,
          "beginsPattern": ".",
          "endsPattern": "Convex functions ready"
        }
      },
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "group": "dev"
      },
      "runOptions": {
        "runOn": "folderOpen"
      }
    }
  ]
}

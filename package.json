{
  "name": "orca",
  "private": true,
  "workspaces": [
    "apps/**",
    "packages/**"
  ],
  "type": "module",
  "scripts": {
    "archive-sync": "turbo run archive-sync --filter=web",
    "build": "turbo run build --filter=web",
    "check": "ultracite check --type-aware --type-check",
    "dev": "turbo run dev",
    "dev:backend": "turbo run dev --filter=@orca/backend",
    "dev:next": "turbo run dev --filter=web",
    "fix": "ultracite fix --type-aware --type-check",
    "knip": "knip",
    "knip:production": "knip --production",
    "logos": "bun run --cwd apps/logos build",
    "prepare": "husky",
    "release": "turbo run release --filter=web",
    "start": "turbo run start --filter=web"
  },
  "devDependencies": {
    "@types/bun": "catalog:",
    "@types/node": "catalog:",
    "eslint-plugin-react-hooks": "7.1.1",
    "husky": "^9.1.7",
    "knip": "6.26.0",
    "lint-staged": "^17.0.8",
    "oxfmt": "^0.59.0",
    "oxlint": "^1.74.0",
    "oxlint-tsgolint": "0.21.1",
    "turbo": "^2.10.5",
    "typescript": "catalog:",
    "ultracite": "7.6.0"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx,json,jsonc,css,scss,md,mdx}": [
      "bun x ultracite fix --type-aware --type-check"
    ]
  },
  "packageManager": "bun@1.3.14",
  "catalog": {
    "@types/bun": "1.3.14",
    "@types/node": "24.10.15",
    "convex": "1.42.3",
    "convex-helpers": "0.1.120",
    "pretty-bytes": "7.1.0",
    "remeda": "2.39.0",
    "typescript": "^6",
    "zod": "4.4.3"
  }
}

{
  "name": "orca",
  "private": true,
  "workspaces": [
    "apps/**",
    "packages/**"
  ],
  "type": "module",
  "scripts": {
    "archive-sync": "turbo run archive-sync --filter=web",
    "build": "turbo run build --filter=web",
    "check": "oxlint --type-check --type-aware --report-unused-disable-directives --fix . && oxfmt --write . && echo '✓ check passed'",
    "dev": "turbo run dev --ui=stream",
    "dev:convex": "turbo run dev --filter=@orca/backend",
    "dev:next": "turbo run dev --filter=web",
    "knip": "knip",
    "knip:production": "knip --production",
    "process-logos": "turbo run process-logos --filter=web",
    "release": "turbo run release --filter=web",
    "start": "turbo run start --filter=web"
  },
  "devDependencies": {
    "eslint-plugin-react-hooks": "7.1.1",
    "knip": "6.6.0",
    "oxfmt": "0.46.0",
    "oxlint": "1.61.0",
    "oxlint-tsgolint": "0.21.1",
    "turbo": "^2.9.6",
    "typescript": "catalog:",
    "ultracite": "7.6.0"
  },
  "packageManager": "bun@1.3.13",
  "catalog": {
    "@types/bun": "1.3.13",
    "@types/node": "24.10.15",
    "convex": "1.36.1",
    "convex-helpers": "0.1.115",
    "pretty-bytes": "7.1.0",
    "remeda": "2.33.7",
    "typescript": "5.9.3",
    "zod": "4.3.6"
  }
}

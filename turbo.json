{
  "$schema": "https://turborepo.dev/schema.json",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": [".next/**", "!.next/cache/**"]
    },
    "dev:convex": {
      "cache": false,
      "persistent": true
    },
    "dev:next": {
      "cache": false,
      "persistent": true
    },
    "start": {
      "cache": false,
      "persistent": true
    },
    "archive-sync": {
      "cache": false
    },
    "process-logos": {
      "cache": false
    },
    "release": {
      "cache": false
    }
  }
}
